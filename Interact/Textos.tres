&"1_1": {
"dialogue": "Ninguém agua essa planta faz muito tempo…",
"offset": Vector2(220, 100),
"options": {
0: {
"condition": Array[Dictionary]([]),
"link": "END",
"text": ""
}
},
"size": Vector2(439.9997, 326),
"speaker": ""
},
&"1_2": {
"dialogue": "Um enorme mapa na parede, cheio de alfinetes vermelhos marcando os lugares que ela ainda queria conhecer.",
"offset": Vector2(240, 480),
"options": {
0: {
"condition": Array[Dictionary]([]),
"link": &"1_3",
"text": ""
}
},
"size": Vector2(420.00018, 286.00006),
"speaker": ""
},
&"1_3": {
"dialogue": " O alfinete mais recente está cravado bem em cima de uma rota de estrada... uma viagem que ela nunca chegou a fazer.
",
"offset": Vector2(700, 480),
"options": {
0: {
"condition": Array[Dictionary]([]),
"link": "END",
"text": ""
}
},
"size": Vector2(300.00003, 286.00006),
"speaker": ""
},
&"1_4": {
"dialogue": "Uma boneca dentro da outra, que gracinha.",
"offset": Vector2(240, 820),
"options": {
0: {
"condition": Array[Dictionary]([]),
"link": "END",
"text": ""
}
},
"size": Vector2(420.00018, 286.00006),
"speaker": ""
},
&"1_5": {
"dialogue": "O borrifador ainda guarda o aroma de jasmim. Fecho os olhos e, por um segundo, ela está aqui.",
"offset": Vector2(240, 1120),
"options": {
0: {
"condition": Array[Dictionary]([]),
"link": "END",
"text": ""
}
},
"size": Vector2(419.99994, 286.00006),
"speaker": ""
},
&"1_6": {
"dialogue": "Ela adorava ler e escrever, e o grande sonho dela era publicar um livro autoral.",
"offset": Vector2(240, 1440),
"options": {
0: {
"condition": Array[Dictionary]([]),
"link": &"1_7",
"text": ""
}
},
"size": Vector2(419.99994, 286.00006),
"speaker": ""
},
&"1_7": {
"dialogue": "A folha ainda está no rolo, mas a história parou na metade do capítulo.",
"offset": Vector2(700, 1440),
"options": {
0: {
"condition": Array[Dictionary]([]),
"link": "END",
"text": ""
}
},
"size": Vector2(300.00003, 286.00006),
"speaker": ""
},
&"1_8": {
"dialogue": "Ah, esse era o vestido favorito dela. Ela sempre o usava no aniversário dela. Olhando para ele agora, pendurado no cabide, algo parece estranho…",
"offset": Vector2(240, 1780),
"options": {
0: {
"condition": Array[Dictionary]([]),
"link": "END",
"text": ""
}
},
"size": Vector2(420.00018, 246.00006),
"speaker": ""
}
}
